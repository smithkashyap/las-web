{
  "type": "container",
  "style": {
    "display": "flex",
    "flexDirection": "column",
    "padding": "20px",
    "gap": "20px"
  },
  "children": [
    {
      "type": "container",
      "style": {
        "display": "flex",
        "alignItems": "center",
        "gap": "16px"
      },
      "children": [
        {
          "type": "button",
          "props": {
            "icon": "arrow-left",
            "iconSize": 20,
            "iconColor": "#f1f5f9",
            "action": {
              "type": "goBack"
            }
          },
          "style": {
            "width": "40px",
            "height": "40px",
            "borderRadius": "50%",
            "backgroundColor": "#111827",
            "border": "1px solid #1e293b",
            "display": "flex",
            "alignItems": "center",
            "justifyContent": "center",
            "cursor": "pointer",
            "padding": "0"
          }
        },
        {
          "type": "text",
          "props": {
            "value": "KYC Verification",
            "variant": "h4"
          },
          "style": {
            "color": "#f1f5f9"
          }
        }
      ]
    },
    {
      "type": "container",
      "style": {
        "width": "100%",
        "height": "6px",
        "borderRadius": "4px",
        "backgroundColor": "#1e293b"
      },
      "children": [
        {
          "type": "container",
          "style": {
            "height": "6px",
            "width": "40%",
            "borderRadius": "4px",
            "backgroundColor": "#3b82f6"
          }
        }
      ]
    },
    {
      "type": "text",
      "props": {
        "value": "Complete all checks. Typically 5–10 mins.",
        "variant": "body"
      },
      "style": {
        "color": "#94a3b8",
        "lineHeight": "1.5"
      }
    },
    {
      "type": "dynamic-list",
      "props": {
        "itemType": "kyc-item",
        "items": [
          {
            "icon": "🪪",
            "title": "PAN Verification",
            "subtitle": "NSDL · Auto-fetched",
            "status": "done"
          },
          {
            "icon": "🏛️",
            "title": "Aadhaar e-KYC",
            "subtitle": "DigiLocker OTP consent",
            "status": "done"
          },
          {
            "icon": "🤳",
            "title": "Selfie / Liveness",
            "subtitle": "Face match with Aadhaar",
            "stateKey": "selfieDone",
            "action": {
              "type": "api",
              "payload": {
                "api": "selfieCheck",
                "onSuccess": {
                  "type": "setState",
                  "payload": {
                    "key": "selfieDone",
                    "value": true
                  }
                }
              }
            }
          },
          {
            "icon": "🏧",
            "title": "Bank Account",
            "subtitle": "For disbursement",
            "status": "pending"
          },
          {
            "icon": "✍️",
            "title": "e-Sign (eNACH)",
            "subtitle": "Loan agreement via Aadhaar",
            "status": "pending"
          }
        ]
      }
    },
    {
      "type": "button",
      "props": {
        "label": "Next: Selfie Check",
        "action": {
          "type": "navigate",
          "payload": {
            "route": ""
          }
        }
      },
      "style": {
        "width": "100%",
        "padding": "16px",
        "borderRadius": "16px",
        "border": "none",
        "background": "linear-gradient(135deg, #3b82f6, #60a5fa)",
        "color": "#ffffff",
        "fontSize": "14px",
        "fontWeight": "600",
        "cursor": "pointer"
      }
    }
  ]
}