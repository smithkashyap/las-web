{
  "type": "container",
  "props": {
    "variant": "page"
  },
  "children": [
    {
      "type": "container",
      "props": {
        "variant": "flex"
      },
      "style": {
        "gap": "20px",
        "padding": "20px",
        "flex": "1",
        "overflowY": "auto"
      },
      "children": [
        {
          "type": "container",
          "props": {
            "variant": "row"
          },
          "style": {
            "gap": "16px"
          },
          "children": [
            {
              "type": "button",
              "props": {
                "icon": "arrow-left",
                "iconSize": 20,
                "iconColor": "#FBFBFB",
                "action": {
                  "type": "goBack"
                },
                "variant": "icon",
                "size": "md"
              },
              "style": {
                "width": "40px",
                "height": "40px",
                "padding": "0"
              }
            },
            {
              "type": "text",
              "props": {
                "value": "Eligible for Pledge",
                "variant": "h3"
              }
            }
          ]
        },
        {
          "type": "container",
          "props": {
            "variant": "info"
          },
          "children": [
            {
              "type": "text",
              "props": {
                "value": "Showing: your holdings ∩ lender-approved securities list",
                "variant": "bodySmall",
                "colorVariant": "info"
              },
              "style": {
                "lineHeight": "1.4"
              }
            }
          ]
        },
        {
          "type": "container",
          "props": {
            "variant": "card",
            "size": "lg"
          },
          "style": {
            "display": "flex",
            "flexDirection": "column",
            "gap": "8px"
          },
          "children": [
            {
              "type": "container",
              "props": {
                "variant": "between"
              },
              "children": [
                {
                  "type": "text",
                  "props": {
                    "value": "Eligible Portfolio Value",
                    "variant": "bodySmall",
                    "colorVariant": "secondary"
                  }
                },
                {
                  "type": "container",
                  "style": {
                    "backgroundColor": "#28A74526",
                    "padding": "4px 10px",
                    "borderRadius": "8px"
                  },
                  "children": [
                    {
                      "type": "text",
                      "props": {
                        "value": "4 / 5 qualify",
                        "variant": "badge",
                        "colorVariant": "success"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "text",
              "props": {
                "value": "{{eligibleTotal}}",
                "variant": "h2"
              }
            },
            {
              "type": "container",
              "props": {
                "variant": "between"
              },
              "children": [
                {
                  "type": "text",
                  "props": {
                    "value": "Max Loan Amount",
                    "variant": "bodySmall",
                    "colorVariant": "secondary"
                  }
                },
                {
                  "type": "text",
                  "props": {
                    "value": "{{loanTotal}}",
                    "variant": "h3",
                    "colorVariant": "success"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "infinite-selectable-list",
          "props": {
            "selectionKey": "pledgeAssets",
            "itemsPerPage": 5,
            "emptyTitle": "No eligible assets found",
            "emptySubtitle": "Eligible pledge assets will appear here.",
            "dataSource": {
              "type": "json",
              "api": "/data/eligiblePledge.json",
              "mockDelayMs": 700,
              "query": { "type": "eligibleAssets" }
            }
          }
        }
      ]
    },
    {
      "type": "container",
      "style": {
        "position": "sticky",
        "bottom": "0",
        "backgroundColor": "#121212",
        "padding": "16px 20px"
      },
      "children": [
        {
          "type": "button",
          "props": {
            "disabled": "{{isCtaDisabled}}",
            "label": "Proceed to KYC →",
            "action": {
              "type": "navigate",
              "payload": {
                "route": "/kyc-verification"
              }
            },
            "variant": "primary",
            "size": "lg"
          }
        }
      ]
    }
  ]
}
