{
  "type": "container",
  "props": {
    "variant": "page"
  },
  "children": [
    {
      "type": "container",
      "props": {
        "variant": "flex"
      },
      "style": {
        "gap": "20px",
        "padding": "20px",
        "flex": "1",
        "minHeight": "0",
        "overflow": "hidden"
      },
      "children": [
        {
          "type": "container",
          "props": {
            "variant": "row"
          },
          "style": {
            "gap": "16px"
          },
          "children": [
            {
              "type": "button",
              "props": {
                "icon": "arrow-left",
                "iconSize": 20,
                "iconColor": "#FBFBFB",
                "action": {
                  "type": "goBack"
                },
                "variant": "icon",
                "size": "md"
              },
              "style": {
                "width": "40px",
                "height": "40px",
                "padding": "0"
              }
            },
            {
              "type": "text",
              "props": {
                "value": "Your Portfolio",
                "variant": "h3"
              }
            }
          ]
        },
        {
          "type": "tab-bar",
          "props": {
            "stateKey": "activeTab",
            "defaultValue": "shares",
            "tabs": [
              {
                "key": "shares",
                "label": "Shares (12)"
              },
              {
                "key": "mf",
                "label": "Mutual Funds (8)"
              }
            ],
            "containerStyle": {
              "display": "flex",
              "gap": "8px",
              "width": "100%"
            },
            "activeStyle": {
              "flex": 1,
              "padding": "12px",
              "borderRadius": "12px",
              "backgroundColor": "#00A9EB",
              "border": "1px solid #00A9EB",
              "textAlign": "center"
            },
            "inactiveStyle": {
              "flex": 1,
              "padding": "12px",
              "borderRadius": "12px",
              "backgroundColor": "transparent",
              "border": "1px solid #3A4048",
              "textAlign": "center"
            },
            "activeTextStyle": {
              "color": "#FBFBFB",
              "fontSize": "12px",
              "fontWeight": "600"
            },
            "inactiveTextStyle": {
              "color": "#878787",
              "fontSize": "12px",
              "fontWeight": "600"
            }
          }
        },
        {
          "type": "container",
          "props": {
            "variant": "card",
            "size": "lg"
          },
          "style": {
            "display": "flex",
            "flexDirection": "column",
            "gap": "8px"
          },
          "children": [
            {
              "type": "container",
              "props": {
                "variant": "between"
              },
              "children": [
                {
                  "type": "text",
                  "props": {
                    "value": "Total Portfolio Value",
                    "variant": "caption",
                    "colorVariant": "secondary"
                  }
                },
                {
                  "type": "container",
                  "style": {
                    "backgroundColor": "#00A9EB26",
                    "padding": "4px 10px",
                    "borderRadius": "8px"
                  },
                  "children": [
                    {
                      "type": "text",
                      "props": {
                        "value": "Zerodha",
                        "variant": "badge",
                        "colorVariant": "info"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "text",
              "props": {
                "value": "₹14,82,340",
                "variant": "h2Large",
                "colorVariant": "primary"
              }
            },
            {
              "type": "text",
              "props": {
                "value": "As of 09 Apr 2026 · 4:00 PM IST",
                "variant": "caption",
                "colorVariant": "secondary"
              }
            }
          ]
        },
        {
          "type": "container",
          "props": {
            "variant": "flex"
          },
          "style": {
            "flex": "1",
            "minHeight": "0",
            "gap": "12px"
          },
          "children": [
            {
              "type": "text",
              "props": {
                "value": "Holdings",
                "variant": "bodyMedium",
                "colorVariant": "secondary"
              }
            },
            {
              "type": "container",
              "style": {
                "flex": "1",
                "minHeight": "0",
                "display": "flex",
                "flexDirection": "column"
              },
              "children": [
                {
                  "type": "value-switch",
                  "props": {
                    "stateKey": "activeTab",
                    "cases": {
                      "shares": {
                        "type": "paginated-list",
                        "props": {
                          "itemType": "holding-card",
                          "itemsPerPage": 5,
                          "emptyTitle": "No shares found",
                          "emptySubtitle": "Your fetched share holdings will appear here.",
                          "dataSource": {
                            "type": "json",
                            "api": "/data/portfolioHoldings.json",
                            "query": { "type": "shares" }
                          }
                        }
                      },
                      "mf": {
                        "type": "paginated-list",
                        "props": {
                          "itemType": "holding-card",
                          "itemsPerPage": 5,
                          "emptyTitle": "No mutual funds found",
                          "emptySubtitle": "Your fetched mutual fund holdings will appear here.",
                          "dataSource": {
                            "type": "json",
                            "api": "/data/portfolioHoldings.json",
                            "query": { "type": "mf" }
                          }
                        }
                      }
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "container",
      "style": {
        "position": "sticky",
        "bottom": "0",
        "backgroundColor": "#121212",
        "padding": "16px 20px"
      },
      "children": [
        {
          "type": "button",
          "props": {
            "label": "See Eligible for Loan →",
            "action": {
              "type": "navigate",
              "payload": {
                "route": "/eligible-pledge"
              }
            },
            "variant": "primary",
            "size": "lg"
          }
        }
      ]
    }
  ]
}
