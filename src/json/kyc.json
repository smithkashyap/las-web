{
  "type": "container",
  "style": {
    "display": "flex",
    "flexDirection": "column",
    "padding": "20px",
    "gap": "24px"
  },
  "children": [
    {
      "type": "button",
      "props": {
        "icon": "arrow-left",
        "iconSize": 20,
        "iconColor": "#f1f5f9",
        "action": {
          "type": "goBack"
        }
      },
      "style": {
        "width": "40px",
        "height": "40px",
        "borderRadius": "50%",
        "backgroundColor": "#111827",
        "border": "1px solid #1e293b",
        "display": "flex",
        "alignItems": "center",
        "justifyContent": "center",
        "cursor": "pointer",
        "padding": "0"
      }
    },
    {
      "type": "container",
      "style": {
        "height": "4px",
        "width": "25%",
        "borderRadius": "4px",
        "backgroundColor": "#3b82f6"
      }
    },
    {
      "type": "text",
      "props": {
        "value": "Tell us about you",
        "variant": "h2"
      },
      "style": {
        "color": "#f1f5f9"
      }
    },
    {
      "type": "text",
      "props": {
        "value": "We collect this to verify your identity and match your investment portfolio.",
        "variant": "body"
      },
      "style": {
        "color": "#94a3b8",
        "lineHeight": "1.5"
      }
    },
    {
      "type": "container",
      "style": {
        "display": "flex",
        "flexDirection": "column",
        "gap": "20px"
      },
      "children": [
        {
          "type": "container",
          "style": {
            "display": "flex",
            "flexDirection": "column",
            "gap": "8px"
          },
          "children": [
            {
              "type": "text",
              "props": {
                "value": "Full Name (as per PAN)",
                "variant": "label"
              },
              "style": {
                "color": "#94a3b8"
              }
            },
            {
              "type": "input",
              "props": {
                "placeholder": "Rahul Sharma",
                "stateKey": "fullName",
                "validation": {
                  "rules": [
                    {
                      "type": "required",
                      "message": "Full name is required"
                    }
                  ]
                }
              },
              "style": {
                "width": "100%",
                "padding": "14px 16px",
                "borderRadius": "12px",
                "border": "1px solid #1e293b",
                "backgroundColor": "#0f172a",
                "color": "#f1f5f9",
                "fontSize": "14px",
                "outline": "none",
                "boxSizing": "border-box"
              }
            }
          ]
        },
        {
          "type": "container",
          "style": {
            "display": "flex",
            "flexDirection": "column",
            "gap": "8px"
          },
          "children": [
            {
              "type": "text",
              "props": {
                "value": "PAN Number",
                "variant": "label"
              },
              "style": {
                "color": "#94a3b8"
              }
            },
            {
              "type": "input",
              "props": {
                "placeholder": "ABCPS1234K",
                "maxLength": 10,
                "stateKey": "pan",
                "validation": {
                  "rules": [
                    {
                      "type": "required",
                      "message": "PAN is mandatory"
                    },
                    {
                      "type": "pan",
                      "message": "Invalid PAN format"
                    }
                  ]
                }
              },
              "style": {
                "width": "100%",
                "padding": "14px 16px",
                "borderRadius": "12px",
                "border": "1px solid #1e293b",
                "backgroundColor": "#0f172a",
                "color": "#f1f5f9",
                "fontSize": "14px",
                "outline": "none",
                "boxSizing": "border-box",
                "textTransform": "uppercase"
              }
            },
            {
              "type": "text",
              "props": {
                "value": "Used for portfolio matching & KYC",
                "variant": "caption"
              },
              "style": {
                "color": "#94a3b8",
                "opacity": "0.7"
              }
            }
          ]
        },
        {
          "type": "container",
          "style": {
            "display": "flex",
            "flexDirection": "column",
            "gap": "8px"
          },
          "children": [
            {
              "type": "text",
              "props": {
                "value": "Date of Birth",
                "variant": "label"
              },
              "style": {
                "color": "#94a3b8"
              }
            },
            {
              "type": "date-input",
              "props": {
                "placeholder": "DD / MM / YYYY",
                "stateKey": "dob",
                "validation": {
                  "rules": [
                    {
                      "type": "required",
                      "message": "Date of birth is required"
                    },
                    {
                      "type": "dob",
                      "message": "Invalid date of birth"
                    }
                  ]
                },
                "inputStyle": {
                  "width": "100%",
                  "padding": "14px 16px",
                  "borderRadius": "12px",
                  "border": "1px solid #1e293b",
                  "backgroundColor": "#0f172a",
                  "color": "#f1f5f9",
                  "fontSize": "14px",
                  "outline": "none",
                  "boxSizing": "border-box"
                }
              }
            }
          ]
        },
        {
          "type": "container",
          "style": {
            "display": "flex",
            "flexDirection": "column",
            "gap": "8px"
          },
          "children": [
            {
              "type": "text",
              "props": {
                "value": "Mobile Number",
                "variant": "label"
              },
              "style": {
                "color": "#94a3b8"
              }
            },
            {
              "type": "container",
              "style": {
                "display": "flex",
                "gap": "12px"
              },
              "children": [
                {
                  "type": "container",
                  "style": {
                    "display": "flex",
                    "alignItems": "center",
                    "padding": "14px 16px",
                    "borderRadius": "12px",
                    "border": "1px solid #1e293b",
                    "backgroundColor": "#0f172a"
                  },
                  "children": [
                    {
                      "type": "text",
                      "props": {
                        "value": "+91",
                        "variant": "label"
                      },
                      "style": {
                        "color": "#94a3b8"
                      }
                    }
                  ]
                },
                {
                  "type": "input",
                  "props": {
                    "placeholder": "98765 43210",
                    "inputType": "tel",
                    "format": "phone",
                    "stateKey": "mobile",
                    "validation": {
                      "rules": [
                        {
                          "type": "required",
                          "message": "Mobile number is required"
                        },
                        {
                          "type": "regex",
                          "pattern": "^[0-9]{5}\\s?[0-9]{5}$",
                          "message": "Enter valid 10-digit mobile number"
                        }
                      ]
                    }
                  },
                  "style": {
                    "flex": "1",
                    "padding": "14px 16px",
                    "borderRadius": "12px",
                    "border": "1px solid #1e293b",
                    "backgroundColor": "#0f172a",
                    "color": "#f1f5f9",
                    "fontSize": "14px",
                    "outline": "none",
                    "boxSizing": "border-box"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "container",
          "style": {
            "display": "flex",
            "flexDirection": "column",
            "gap": "8px"
          },
          "children": [
            {
              "type": "text",
              "props": {
                "value": "Email Address",
                "variant": "label"
              },
              "style": {
                "color": "#94a3b8"
              }
            },
            {
              "type": "input",
              "props": {
                "placeholder": "rahul.sharma@gmail.com",
                "inputType": "email",
                "stateKey": "email",
                "validation": {
                  "rules": [
                    {
                      "type": "required",
                      "message": "Email is required"
                    },
                    {
                      "type": "email",
                      "message": "Invalid email address"
                    }
                  ]
                }
              },
              "style": {
                "width": "100%",
                "padding": "14px 16px",
                "borderRadius": "12px",
                "border": "1px solid #1e293b",
                "backgroundColor": "#0f172a",
                "color": "#f1f5f9",
                "fontSize": "14px",
                "outline": "none",
                "boxSizing": "border-box"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "checkbox",
      "props": {
        "label": "I agree to T&C and authorise LoansOn to fetch my portfolio data via AA framework.",
        "stateKey": "tncAccepted"
      },
      "style": {
        "fontSize": "12px",
        "color": "#94a3b8"
      }
    },
    {
      "type": "button",
      "props": {
        "label": "Send OTP to Verify",
        "disabledWhenFalse": "tncAccepted",
        "disableWhenInvalid": true,
        "validateFields": [
          "fullName",
          "pan",
          "dob",
          "mobile",
          "email"
        ],
        "action": {
          "type": "api",
          "payload": {
            "api": "submitKyc",
            "onSuccess": {
              "type": "navigate",
              "payload": {
                "route": "/otp"
              }
            },
            "onError": {
              "type": "navigate",
              "payload": {
                "route": "/otp"
              }
            }
          }
        }
      },
      "style": {
        "width": "100%",
        "padding": "16px",
        "borderRadius": "16px",
        "border": "none",
        "background": "linear-gradient(135deg, #3b82f6, #60a5fa)",
        "color": "#ffffff",
        "fontSize": "16px",
        "fontWeight": "600",
        "cursor": "pointer"
      }
    }
  ]
}
